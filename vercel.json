{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/nestjs"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "installCommand": "pnpm install --legacy-peer-deps --shamefully-hoist --strict-peer-dependencies=false",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist"
}