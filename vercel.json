{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/nestjs"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}